{
  "entities": {
    "Notice": {
      "title": "Notice",
      "description": "A notice or announcement for the madrasa.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the notice." },
        "content": { "type": "string", "description": "The full content of the notice." },
        "date": { "type": "string", "format": "date-time", "description": "The date the notice was published." },
        "category": { "type": "string", "enum": ["general", "admission", "exam", "holiday"], "description": "The category of the notice." }
      },
      "required": ["title", "content", "date", "category"]
    },
    "Admission": {
      "title": "Admission",
      "description": "An admission application submitted by a student.",
      "type": "object",
      "properties": {
        "studentName": { "type": "string", "description": "The full name of the student." },
        "fatherName": { "type": "string", "description": "The father's name." },
        "motherName": { "type": "string", "description": "The mother's name." },
        "dob": { "type": "string", "format": "date", "description": "Date of birth." },
        "gender": { "type": "string", "enum": ["male", "female"], "description": "Gender of the student." },
        "department": { "type": "string", "description": "The department applied for." },
        "phone": { "type": "string", "description": "Contact phone number." },
        "address": { "type": "string", "description": "Full address." },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Current status of the application." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Submission timestamp." }
      },
      "required": ["studentName", "fatherName", "motherName", "dob", "gender", "department", "phone", "address", "status", "createdAt"]
    },
    "Result": {
      "title": "Result",
      "description": "Examination result for a student.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string", "description": "The unique ID of the student." },
        "studentName": { "type": "string", "description": "The name of the student." },
        "class": { "type": "string", "description": "The class or department." },
        "gpa": { "type": "string", "description": "The GPA achieved." },
        "status": { "type": "string", "enum": ["উত্তীর্ণ", "অনুত্তীর্ণ"], "description": "Pass/Fail status." },
        "subjects": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "marks": { "type": "string" }
            }
          }
        }
      },
      "required": ["studentId", "studentName", "class", "gpa", "status", "subjects"]
    },
    "GalleryItem": {
      "title": "GalleryItem",
      "description": "An image item in the gallery.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the image." },
        "url": { "type": "string", "format": "uri", "description": "The URL of the image." },
        "category": { "type": "string", "description": "The category of the image." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Upload timestamp." }
      },
      "required": ["title", "url", "category", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "A user of the system with administrative roles.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "role": { "type": "string", "enum": ["admin", "staff"], "description": "The user's role." }
      },
      "required": ["name", "email", "role"]
    },
    "Message": {
      "title": "Message",
      "description": "A contact message from a user.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The sender's name." },
        "email": { "type": "string", "format": "email", "description": "The sender's email." },
        "subject": { "type": "string", "description": "The message subject." },
        "message": { "type": "string", "description": "The message content." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Submission timestamp." }
      },
      "required": ["name", "email", "subject", "message", "createdAt"]
    }
  },
  "firestore": {
    "/notices/{noticeId}": { "schema": "Notice", "description": "Collection of madrasa notices." },
    "/admissions/{admissionId}": { "schema": "Admission", "description": "Collection of admission applications." },
    "/results/{resultId}": { "schema": "Result", "description": "Collection of student results." },
    "/gallery/{galleryId}": { "schema": "GalleryItem", "description": "Collection of gallery images." },
    "/users/{userId}": { "schema": "User", "description": "Collection of system users." },
    "/messages/{messageId}": { "schema": "Message", "description": "Collection of contact messages." }
  }
}
